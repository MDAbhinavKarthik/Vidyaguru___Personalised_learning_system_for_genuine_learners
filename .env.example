# VidyaGuru - Environment Variables
# Copy this file to .env and fill in the values

# Application
ENVIRONMENT=development
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://vidyaguru:your_secure_password@localhost:5432/vidyaguru
DB_PASSWORD=your_secure_password

# Security
SECRET_KEY=your-super-secret-key-change-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI/LLM Configuration
GEMINI_API_KEY=your-gemini-api-key
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash
LLM_MAX_TOKENS=2000
LLM_TEMPERATURE=0.7

# CORS Origins (comma-separated)
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# Redis (optional)
REDIS_URL=redis://localhost:6379/0

# Email (optional - for password reset, verification)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# PgAdmin (development)
PGADMIN_PASSWORD=admin
