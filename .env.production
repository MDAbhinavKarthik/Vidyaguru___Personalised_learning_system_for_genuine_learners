# Production Environment Configuration
# Use these for Vercel & Render deployment

# ============================================================================
# FRONTEND (Vercel)
# ============================================================================
NEXT_PUBLIC_API_URL=https://vidyaguru-backend-xxxxx.onrender.com

# ============================================================================
# BACKEND (Render) - PostgreSQL Database
# ============================================================================
# Format: postgresql+asyncpg://username:password@host:port/database
DATABASE_URL=postgresql+asyncpg://vidyaguru:PASSWORD@postgres-instance-xxxxx.c.aivencloud.com:12345/vidyaguru

# ============================================================================
# BACKEND - Redis Cache
# ============================================================================
# Format: redis://:password@host:port
REDIS_URL=redis://:PASSWORD@redis-instance-xxxxx.c.aivencloud.com:12345

# ============================================================================
# BACKEND - Security
# ============================================================================
# Generate with: openssl rand -base64 32
SECRET_KEY=your-secret-key-here-minimum-32-characters-required

# ============================================================================
# BACKEND - AI Integration
# ============================================================================
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ============================================================================
# BACKEND - CORS Configuration
# ============================================================================
# Comma-separated list of allowed origins
CORS_ORIGINS=["https://vidyaguru-xxxxx.vercel.app"]

# ============================================================================
# BACKEND - Environment
# ============================================================================
ENVIRONMENT=production
LOG_LEVEL=INFO

# ============================================================================
# BACKEND - JWT Expiration (in minutes)
# ============================================================================
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
